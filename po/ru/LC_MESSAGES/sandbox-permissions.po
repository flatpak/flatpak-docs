#: ../../sandbox-permissions.rst:2
msgid "Sandbox Permissions"
msgstr "–†–∞–Ј—А–µ—И–µ–љ–Є—П –њ–µ—Б–Њ—З–љ–Є—Ж—Л"

#: ../../sandbox-permissions.rst:4
msgid ""
"One of Flatpak's main goals is to increase the security of desktop "
"systems by isolating applications from one another. This is achieved "
"using sandboxing and means that, by default, applications that are run "
"with Flatpak have extremely limited access to the host environment. This "
"includes:"
msgstr ""
"–Ю–і–љ–∞ –Є–Ј –Њ—Б–љ–Њ–≤–љ—Л—Е —Ж–µ–ї–µ–є Flatpak - –њ–Њ–≤—Л—Б–Є—В—М –±–µ–Ј–Њ–њ–∞—Б–љ–Њ—Б—В—М –љ–∞—Б—В–Њ–ї—М–љ—Л—Е —Б–Є—Б—В–µ–Љ "
"–Ј–∞ —Б—З–µ—В –Є–Ј–Њ–ї—П—Ж–Є–Є –њ—А–Є–ї–Њ–ґ–µ–љ–Є–є –і—А—Г–≥ –Њ—В –і—А—Г–≥–∞. –≠—В–Њ –і–Њ—Б—В–Є–≥–∞–µ—В—Б—П —Б –њ–Њ–Љ–Њ—Й—М—О "
"–њ–µ—Б–Њ—З–љ–Є—Ж—Л –Є –Њ–Ј–љ–∞—З–∞–µ—В, —З—В–Њ –њ–Њ —Г–Љ–Њ–ї—З–∞–љ–Є—О –њ—А–Є–ї–Њ–ґ–µ–љ–Є—П, –Ј–∞–њ—Г—Б–Ї–∞–µ–Љ—Л–µ —Б Flatpak,"
" –Є–Љ–µ—О—В —З—А–µ–Ј–≤—Л—З–∞–є–љ–Њ –Њ–≥—А–∞–љ–Є—З–µ–љ–љ—Л–є –і–Њ—Б—В—Г–њ –Ї —Б—А–µ–і–µ —Е–Њ—Б—В–∞. –≠—В–Њ –≤–Ї–ї—О—З–∞–µ—В:"

#: ../../sandbox-permissions.rst:9
msgid ""
"No access to any host files except the runtime, the app, "
"``~/.var/app/$FLATPAK_ID``, and ``$XDG_RUNTIME_DIR/app/$FLATPAK_ID``. "
"Only the latter two being writable."
msgstr ""
"–Э–µ—В –і–Њ—Б—В—Г–њ–∞ –Ї –Ї–∞–Ї–Є–Љ-–ї–Є–±–Њ —Д–∞–є–ї–∞–Љ —Е–Њ—Б—В–∞, –Ї—А–Њ–Љ–µ —Б—А–µ–і—Л –≤—Л–њ–Њ–ї–љ–µ–љ–Є—П, "
"–њ—А–Є–ї–Њ–ґ–µ–љ–Є—П, ``~/.var/app/$FLATPAK_ID``, and "
"``$XDG_RUNTIME_DIR/app/$FLATPAK_ID``. –Ґ–Њ–ї—М–Ї–Њ  –і–≤–∞ –њ–Њ—Б–ї–µ–і–љ–Є—Е –і–Њ—Б—В—Г–њ–љ—Л –і–ї—П "
"–Ј–∞–њ–Є—Б–Є."

#: ../../sandbox-permissions.rst:12
msgid "No access to the network."
msgstr "–Э–µ—В –і–Њ—Б—В—Г–њ–∞ –Ї —Б–µ—В–Є."

#: ../../sandbox-permissions.rst:13
msgid "No access to any device nodes (apart from ``/dev/null``, etc)."
msgstr "–Э–µ—В –і–Њ—Б—В—Г–њ–∞ –Ї –Ї–∞–Ї–Є–Љ-–ї–Є–±–Њ —Г–Ј–ї–∞–Љ —Г—Б—В—А–Њ–є—Б—В–≤–∞ (–Ї—А–Њ–Љ–µ ``/dev/null``, etc)."

#: ../../sandbox-permissions.rst:14
msgid "No access to processes outside the sandbox."
msgstr "–Э–µ—В –і–Њ—Б—В—Г–њ–∞ –Ї –њ—А–Њ—Ж–µ—Б—Б–∞–Љ –≤–љ–µ –њ–µ—Б–Њ—З–љ–Є—Ж—Л."

#: ../../sandbox-permissions.rst:15
msgid ""
"Limited syscalls.  For instance, apps can't use nonstandard network "
"socket types or ptrace other processes."
msgstr ""
"–Ю–≥—А–∞–љ–Є—З–µ–љ–љ—Л–µ —Б—З–µ—В–∞.  –Э–∞–њ—А–Є–Љ–µ—А, –њ—А–Є–ї–Њ–ґ–µ–љ–Є—П –љ–µ –Љ–Њ–≥—Г—В –Є—Б–њ–Њ–ї—М–Ј–Њ–≤–∞—В—М "
"–љ–µ—Б—В–∞–љ–і–∞—А—В–љ—Л–µ —В–Є–њ—Л —Б–µ—В–µ–≤—Л—Е —Б–Њ–Ї–µ—В–Њ–≤ –Є–ї–Є –Њ—В—Б–ї–µ–ґ–Є–≤–∞—В—М –і—А—Г–≥–Є–µ –њ—А–Њ—Ж–µ—Б—Б—Л "
"ptrace."

#: ../../sandbox-permissions.rst:17
msgid ""
"Limited access to the session D-Bus instance - an app can only own its "
"own name on the bus."
msgstr ""
"–Ю–≥—А–∞–љ–Є—З–µ–љ–љ—Л–є –і–Њ—Б—В—Г–њ –Ї —Н–Ї–Ј–µ–Љ–њ–ї—П—А—Г —Б–µ–∞–љ—Б–∞ D-Bus - –њ—А–Є–ї–Њ–ґ–µ–љ–Є–µ –Љ–Њ–ґ–µ—В –≤–ї–∞–і–µ—В—М "
"—В–Њ–ї—М–Ї–Њ —Б–Њ–±—Б—В–≤–µ–љ–љ—Л–Љ –Є–Љ–µ–љ–µ–Љ –љ–∞ —И–Є–љ–µ."

#: ../../sandbox-permissions.rst:19
msgid "No access to host services like X11, system D-Bus, or PulseAudio."
msgstr "–Э–µ—В –і–Њ—Б—В—Г–њ–∞ –Ї —Е–Њ—Б—В-—Б–ї—Г–ґ–±–∞–Љ, —В–∞–Ї–Є–Љ –Ї–∞–Ї X11, —Б–Є—Б—В–µ–Љ–љ—Л–є D-Bus –Є–ї–Є PulseAudio."

#: ../../sandbox-permissions.rst:21
msgid ""
"Most applications will need access to some of these resources in order to"
" be useful. This is primarily done during the finishing build stage, "
"which can be configured through the ``finish-args`` section of the "
"manifest file (see :doc:`manifests`)."
msgstr ""
"–С–Њ–ї—М—И–Є–љ—Б—В–≤—Г –њ—А–Є–ї–Њ–ґ–µ–љ–Є–є, —З—В–Њ–±—Л –±—Л—В—М –њ–Њ–ї–µ–Ј–љ—Л–Љ–Є, –њ–Њ—В—А–µ–±—Г–µ—В—Б—П –і–Њ—Б—В—Г–њ –Ї "
"–љ–µ–Ї–Њ—В–Њ—А—Л–Љ –Є–Ј —Н—В–Є—Е —А–µ—Б—Г—А—Б–Њ–≤. –Т –њ–µ—А–≤—Г—О –Њ—З–µ—А–µ–і—М —Н—В–Њ –і–µ–ї–∞–µ—В—Б—П –љ–∞ —Н—В–∞–њ–µ "
"–Ј–∞–≤–µ—А—И–∞—О—Й–µ–є —Б–±–Њ—А–Ї–Є, –Ї–Њ—В–Њ—А—Л–є –Љ–Њ–ґ–љ–Њ –љ–∞—Б—В—А–Њ–Є—В—М –≤ —А–∞–Ј–і–µ–ї–µ ``finish-args`` "
"—Д–∞–є–ї–∞ –Љ–∞–љ–Є—Д–µ—Б—В–∞ (—Б–Љ. :doc:`manifestests`)."

#: ../../sandbox-permissions.rst:27
msgid "Portals"
msgstr "–Я–Њ—А—В–∞–ї—Л"

#: ../../sandbox-permissions.rst:29
msgid ""
"Portals have already been mentioned in :doc:`basic-concepts`. They are a "
"framework for providing access to resources outside of the sandbox, "
"including:"
msgstr ""
"–Я–Њ—А—В–∞–ї—Л —Г–ґ–µ —Г–њ–Њ–Љ–Є–љ–∞–ї–Є—Б—М –≤ :doc:`basic-concepts`. –Ю–љ–Є –њ—А–µ–і—Б—В–∞–≤–ї—П—О—В —Б–Њ–±–Њ–є "
"–Њ—Б–љ–Њ–≤—Г –і–ї—П –њ—А–µ–і–Њ—Б—В–∞–≤–ї–µ–љ–Є—П –і–Њ—Б—В—Г–њ–∞ –Ї —А–µ—Б—Г—А—Б–∞–Љ –Ј–∞ –њ—А–µ–і–µ–ї–∞–Љ–Є –њ–µ—Б–Њ—З–љ–Є—Ж—Л, –≤ "
"—В–Њ–Љ —З–Є—Б–ї–µ:"

#: ../../sandbox-permissions.rst:32
msgid "Opening files with a native file chooser dialog"
msgstr "–Ю—В–Ї—А—Л—В–Є–µ —Д–∞–є–ї–Њ–≤ —Б –њ–Њ–Љ–Њ—Й—М—О —Б–Њ–±—Б—В–≤–µ–љ–љ–Њ–≥–Њ –і–Є–∞–ї–Њ–≥–Њ–≤–Њ–≥–Њ –Њ–Ї–љ–∞ –≤—Л–±–Њ—А–∞ —Д–∞–є–ї–Њ–≤"

#: ../../sandbox-permissions.rst:33
msgid "Opening URIs"
msgstr "–Ю—В–Ї—А—Л—В–Є–µ URIs"

#: ../../sandbox-permissions.rst:34
msgid "Printing"
msgstr "–Я–µ—З–∞—В—М"

#: ../../sandbox-permissions.rst:35
msgid "Showing notifications"
msgstr "–Ю—В–Њ–±—А–∞–ґ–µ–љ–Є–µ —Г–≤–µ–і–Њ–Љ–ї–µ–љ–Є–є"

#: ../../sandbox-permissions.rst:36
msgid "Taking screenshots"
msgstr "–°–љ—П—В–Є–µ —Б–Ї—А–Є–љ—И–Њ—В–Њ–≤"

#: ../../sandbox-permissions.rst:37
msgid ""
"Inhibiting the user session from ending, suspending, idling or getting "
"switched away"
msgstr ""
"–Ч–∞–њ—А–µ—В –њ–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї—М—Б–Ї–Њ–≥–Њ —Б–µ–∞–љ—Б–∞ –љ–∞ –Ј–∞–≤–µ—А—И–µ–љ–Є–µ, –њ—А–Є–Њ—Б—В–∞–љ–Њ–≤–Ї—Г, –њ—А–Њ—Б—В–Њ–є –Є–ї–Є "
"–Њ—В–Ї–ї—О—З–µ–љ–Є–µ"

#: ../../sandbox-permissions.rst:39
msgid "Getting network status information"
msgstr "–Я–Њ–ї—Г—З–µ–љ–Є–µ –Є–љ—Д–Њ—А–Љ–∞—Ж–Є–Є –Њ —Б–Њ—Б—В–Њ—П–љ–Є–Є —Б–µ—В–Є"

#: ../../sandbox-permissions.rst:41
msgid ""
"In many cases, portals use a system component to implicitly ask the user "
"for permission before granting access to a particular resource. For "
"example, in the case of opening a file, the user's selection of a file "
"using the file chooser dialog is interpreted as implicitly granting the "
"application access to whatever file is chosen."
msgstr ""
"–Т–Њ –Љ–љ–Њ–≥–Є—Е —Б–ї—Г—З–∞—П—Е –њ–Њ—А—В–∞–ї—Л –Є—Б–њ–Њ–ї—М–Ј—Г—О—В —Б–Є—Б—В–µ–Љ–љ—Л–є –Ї–Њ–Љ–њ–Њ–љ–µ–љ—В, —З—В–Њ–±—Л –љ–µ—П–≤–љ–Њ "
"–Ј–∞–њ—А–∞—И–Є–≤–∞—В—М —А–∞–Ј—А–µ—И–µ–љ–Є–µ —Г –њ–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї—П –њ–µ—А–µ–і –њ—А–µ–і–Њ—Б—В–∞–≤–ї–µ–љ–Є–µ–Љ –і–Њ—Б—В—Г–њ–∞ –Ї "
"–Њ–њ—А–µ–і–µ–ї–µ–љ–љ–Њ–Љ—Г —А–µ—Б—Г—А—Б—Г. –Э–∞–њ—А–Є–Љ–µ—А, –≤ —Б–ї—Г—З–∞–µ –Њ—В–Ї—А—Л—В–Є—П —Д–∞–є–ї–∞ –≤—Л–±–Њ—А —Д–∞–є–ї–∞ "
"–њ–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї–µ–Љ —Б –њ–Њ–Љ–Њ—Й—М—О –і–Є–∞–ї–Њ–≥–Њ–≤–Њ–≥–Њ –Њ–Ї–љ–∞ –≤—Л–±–Њ—А–∞ —Д–∞–є–ї–∞ –Є–љ—В–µ—А–њ—А–µ—В–Є—А—Г–µ—В—Б—П "
"–Ї–∞–Ї –љ–µ—П–≤–љ–Њ–µ –њ—А–µ–і–Њ—Б—В–∞–≤–ї–µ–љ–Є–µ –њ—А–Є–ї–Њ–ґ–µ–љ–Є—О –і–Њ—Б—В—Г–њ–∞ –Ї –ї—О–±–Њ–Љ—Г –≤—Л–±—А–∞–љ–љ–Њ–Љ—Г —Д–∞–є–ї—Г."

#: ../../sandbox-permissions.rst:47
msgid ""
"This approach enables applications to avoid having to configure blanket "
"access to large amounts of data or services and gives users control over "
"what their applications have access to."
msgstr ""
"–Ґ–∞–Ї–Њ–є –њ–Њ–і—Е–Њ–і –њ–Њ–Ј–≤–Њ–ї—П–µ—В –њ—А–Є–ї–Њ–ґ–µ–љ–Є—П–Љ –Є–Ј–±–µ–ґ–∞—В—М –љ–µ–Њ–±—Е–Њ–і–Є–Љ–Њ—Б—В–Є –љ–∞—Б—В—А–∞–Є–≤–∞—В—М "
"–Њ–±—Й–Є–є –і–Њ—Б—В—Г–њ –Ї –±–Њ–ї—М—И–Є–Љ –Њ–±—К–µ–Љ–∞–Љ –і–∞–љ–љ—Л—Е –Є–ї–Є —Б–ї—Г–ґ–±–∞–Љ –Є –і–∞–µ—В –њ–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї—П–Љ "
"–Ї–Њ–љ—В—А–Њ–ї—М –љ–∞–і —В–µ–Љ, –Ї —З–µ–Љ—Г –Є—Е –њ—А–Є–ї–Њ–ґ–µ–љ–Є—П –Є–Љ–µ—О—В –і–Њ—Б—В—Г–њ."

#: ../../sandbox-permissions.rst:51
#, fuzzy
msgid ""
"Interface toolkits like GTK3 and Qt5 implement transparent support for "
"portals, meaning that applications don't need to do any additional work "
"to use them (it is worth checking which portals each toolkit supports). "
"Applications that aren't using a toolkit with support for portals can "
"refer to the `xdg-desktop-portal API documentation "
"<https://flatpak.github.io/xdg-desktop-portal/>`_ for information on how "
"to use them."
msgstr ""
"–Э–∞–±–Њ—А—Л –Є–љ—Б—В—А—Г–Љ–µ–љ—В–Њ–≤ –Є–љ—В–µ—А—Д–µ–є—Б–∞, —В–∞–Ї–Є–µ –Ї–∞–Ї GTK3 –Є Qt5, —А–µ–∞–ї–Є–Ј—Г—О—В "
"–њ—А–Њ–Ј—А–∞—З–љ—Г—О –њ–Њ–і–і–µ—А–ґ–Ї—Г –њ–Њ—А—В–∞–ї–Њ–≤, –∞ —Н—В–Њ –Њ–Ј–љ–∞—З–∞–µ—В, —З—В–Њ –њ—А–Є–ї–Њ–ґ–µ–љ–Є—П–Љ –љ–µ "
"—В—А–µ–±—Г–µ—В—Б—П –і–Њ–њ–Њ–ї–љ–Є—В–µ–ї—М–љ–Њ–є —А–∞–±–Њ—В—Л –і–ї—П –Є—Е –Є—Б–њ–Њ–ї—М–Ј–Њ–≤–∞–љ–Є—П (—Б—В–Њ–Є—В –њ—А–Њ–≤–µ—А–Є—В—М, "
"–Ї–∞–Ї–Є–µ –њ–Њ—А—В–∞–ї—Л –њ–Њ–і–і–µ—А–ґ–Є–≤–∞–µ—В –Ї–∞–ґ–і—Л–є –љ–∞–±–Њ—А –Є–љ—Б—В—А—Г–Љ–µ–љ—В–Њ–≤). –Я—А–Є–ї–Њ–ґ–µ–љ–Є—П, "
"–Ї–Њ—В–Њ—А—Л–µ –љ–µ –Є—Б–њ–Њ–ї—М–Ј—Г—О—В –Є–љ—Б—В—А—Г–Љ–µ–љ—В–∞—А–Є–є —Б –њ–Њ–і–і–µ—А–ґ–Ї–Њ–є –њ–Њ—А—В–∞–ї–Њ–≤, –Љ–Њ–≥—Г—В "
"–Њ–±—А–∞—В–Є—В—М—Б—П –Ї –і–Њ–Ї—Г–Љ–µ–љ—В–∞—Ж–Є–Є `xdg-desktop-portal API "
"<https://flatpak.github.io/xdg-desktop-portal/portal-docs.html>`_ –і–ї—П "
"–њ–Њ–ї—Г—З–µ–љ–Є—П –Є–љ—Д–Њ—А–Љ–∞—Ж–Є–Є –Њ —В–Њ–Љ, –Ї–∞–Ї –Є—Е –Є—Б–њ–Њ–ї—М–Ј–Њ–≤–∞—В—М."

#: ../../sandbox-permissions.rst:60
msgid "Permissions guidelines"
msgstr "–†–µ–Ї–Њ–Љ–µ–љ–і–∞—Ж–Є–Є –њ–Њ —А–∞–Ј—А–µ—И–µ–љ–Є—П–Љ"

#: ../../sandbox-permissions.rst:64
msgid ""
"Note, that these permissions are completely static and variable expansion"
" or substitution (for example in ``--filesystem`` or ``--env``) is not "
"possible."
msgstr ""

#: ../../sandbox-permissions.rst:68
msgid ""
"While application developers have control over the sandbox permissions "
"they wish to configure, good practice is encouraged and can be enforced. "
"For example, the Flathub hosting service places requirements on which "
"permissions can be used, and software on the host may warn users if "
"certain permissions are used."
msgstr ""
"–•–Њ—В—П —А–∞–Ј—А–∞–±–Њ—В—З–Є–Ї–Є –њ—А–Є–ї–Њ–ґ–µ–љ–Є–є –Є–Љ–µ—О—В –Ї–Њ–љ—В—А–Њ–ї—М –љ–∞–і —А–∞–Ј—А–µ—И–µ–љ–Є—П–Љ–Є –њ–µ—Б–Њ—З–љ–Є—Ж—Л, "
"–Ї–Њ—В–Њ—А—Л–µ –Њ–љ–Є —Е–Њ—В—П—В –љ–∞—Б—В—А–Њ–Є—В—М, —А–µ–Ї–Њ–Љ–µ–љ–і—Г–µ—В—Б—П –њ—А–Є–Љ–µ–љ—П—В—М –њ–µ—А–µ–і–Њ–≤—Л–µ –Љ–µ—В–Њ–і—Л, "
"–Ї–Њ—В–Њ—А—Л–µ –Љ–Њ–≥—Г—В –њ—А–Є–Љ–µ–љ—П—В—М—Б—П. –Э–∞–њ—А–Є–Љ–µ—А, —Б–ї—Г–ґ–±–∞ —Е–Њ—Б—В–Є–љ–≥–∞ Flathub –њ—А–µ–і—К—П–≤–ї—П–µ—В "
"—В—А–µ–±–Њ–≤–∞–љ–Є—П –Ї —В–Њ–Љ—Г, –Ї–∞–Ї–Є–µ —А–∞–Ј—А–µ—И–µ–љ–Є—П –Љ–Њ–≥—Г—В –Є—Б–њ–Њ–ї—М–Ј–Њ–≤–∞—В—М—Б—П, –∞ –њ—А–Њ–≥—А–∞–Љ–Љ–љ–Њ–µ "
"–Њ–±–µ—Б–њ–µ—З–µ–љ–Є–µ –љ–∞ —Е–Њ—Б—В–µ –Љ–Њ–ґ–µ—В –њ—А–µ–і—Г–њ—А–µ–ґ–і–∞—В—М –њ–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї–µ–є, –µ—Б–ї–Є –Є—Б–њ–Њ–ї—М–Ј—Г—О—В—Б—П"
" –Њ–њ—А–µ–і–µ–ї–µ–љ–љ—Л–µ —А–∞–Ј—А–µ—И–µ–љ–Є—П."

#: ../../sandbox-permissions.rst:74
msgid ""
"The following guidelines describe which permissions can be freely used, "
"which can be used on an as-needed basis, and which should be avoided."
msgstr ""
"–°–ї–µ–і—Г—О—Й–Є–µ —А–µ–Ї–Њ–Љ–µ–љ–і–∞—Ж–Є–Є –Њ–њ–Є—Б—Л–≤–∞—О—В, –Ї–∞–Ї–Є–µ —А–∞–Ј—А–µ—И–µ–љ–Є—П –Љ–Њ–ґ–љ–Њ –Є—Б–њ–Њ–ї—М–Ј–Њ–≤–∞—В—М "
